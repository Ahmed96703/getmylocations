# Cloudflare routing rules (v3 — 2026-05-25)
#
# Only the standalone tool pages need explicit rewrite rules to serve
# their .html file at a clean URL.
#
# SPA fallback for unmatched paths is handled automatically by the
# wrangler.json "not_found_handling": "single-page-application" setting,
# so we do NOT add a /* -> /index.html rule (which would create an infinite
# loop with Cloudflare's automatic .html stripping).

/my-location           /my-location.html           200
/gps-coordinates       /gps-coordinates.html       200
/coordinates-converter /coordinates-converter.html 200
/ip-location           /ip-location.html           200
/distance-calculator   /distance-calculator.html   200
/address-finder        /address-finder.html        200
/street-view           /street-view.html           200
/driving-directions    /driving-directions.html    200
