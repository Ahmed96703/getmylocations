# Cloudflare Pages routing rules
# Rules are evaluated TOP to BOTTOM — specific first, catch-all last.
# Status 200 = rewrite (URL stays clean), 301 = permanent redirect.

# ── Standalone tool pages: serve .html files at clean URLs ──
/my-location              /my-location.html              200
/gps-coordinates          /gps-coordinates.html          200
/coordinates-converter    /coordinates-converter.html    200
/ip-location              /ip-location.html              200
/distance-calculator      /distance-calculator.html      200
/address-finder           /address-finder.html           200
/street-view              /street-view.html              200
/driving-directions       /driving-directions.html       200

# ── Legacy URLs from earlier iterations: 301-redirect to canonical ──
/gps-coordinates-converter      /coordinates-converter   301
/gps-coordinates-converter.html /coordinates-converter   301
/ip-location-finder             /ip-location             301
/ip-location-finder.html        /ip-location             301
/my-location.html               /my-location             301
/gps-coordinates.html           /gps-coordinates         301
/coordinates-converter.html     /coordinates-converter   301
/ip-location.html               /ip-location             301
/distance-calculator.html       /distance-calculator     301
/address-finder.html            /address-finder          301
/street-view.html               /street-view             301
/driving-directions.html        /driving-directions      301

# ── React SPA fallback: everything else goes to index.html ──
# React Router will match /, /about, /blog, /privacy-policy, /terms, /disclaimer,
# /fix-location-not-working, /gps-coordinates-finder, /ip-location-lookup,
# /reverse-geocoding, /gps-vs-ip-accuracy, /blog/:slug, etc.
/*                        /index.html                    200
