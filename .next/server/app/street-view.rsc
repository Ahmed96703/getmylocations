0:["8BlH9t38bvsZhjHntO76k",[[["",{"children":["street-view",{"children":["__PAGE__",{}]}]},"$undefined","$undefined",true],["",{"children":["street-view",{"children":["__PAGE__",{},[["$L1",[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"WebApplication\",\"name\":\"Street View Tool\",\"url\":\"https://getmylocations.com/street-view\",\"applicationCategory\":\"UtilitiesApplication\",\"operatingSystem\":\"Web\",\"isAccessibleForFree\":true,\"offers\":{\"@type\":\"Offer\",\"price\":\"0\",\"priceCurrency\":\"USD\"}}"}}],["$","main",null,{"className":"max-w-5xl mx-auto px-5 py-10","children":[["$","section",null,{"className":"mb-8","children":[["$","p",null,{"className":"text-[11px] uppercase tracking-[0.18em] text-accent font-semibold mb-2","children":"Free Tool · Powered by Google Street View"}],["$","h1",null,{"className":"font-display text-4xl sm:text-5xl font-extrabold tracking-tight leading-[1.05]","children":["Street ",["$","span",null,{"className":"text-accent","children":"View"}]," — see any address in Google Street View"]}],["$","p",null,{"className":"text-lg text-fg-muted mt-4 max-w-3xl","children":["Type any address, landmark, or GPS coordinate pair, and instantly walk down the street in ",["$","strong",null,{"className":"text-fg","children":"Google Street View"}],". No signup, no app to install."]}]]}],["$","$L2",null,{}],["$","section",null,{"className":"mt-10","children":[["$","h2",null,{"className":"font-display text-2xl font-bold","children":"How Street View imagery is captured"}],["$","p",null,{"className":"mt-3 text-fg-muted leading-relaxed","children":"Most of the imagery you see comes from cars driving the public road network with a rooftop rig of about nine cameras shooting overlapping panoramas every few meters. Google’s fleet has covered roughly five million miles of public roads since the service launched in 2007. For places cars cannot reach — hiking trails, narrow alleys, museum interiors — the same panoramic kit is mounted on a backpack, a snowmobile, a small boat, or in the case of some museums, a trolley. All of it goes through the same stitching pipeline before it reaches the embed below."}]]}],["$","section",null,{"className":"mt-10","children":[["$","h2",null,{"className":"font-display text-2xl font-bold","children":"Coverage and limitations"}],["$","p",null,{"className":"mt-3 text-fg-muted leading-relaxed","children":"Coverage is uneven and that is a feature of the service, not a bug. Most public roads in North America, western Europe, Japan, South Korea, and Australia have current imagery. Many cities in Pakistan, India, Brazil, and Indonesia have partial coverage — major streets are mapped, side streets are not. A few countries (parts of Germany, until recently, plus most of mainland China, Iran, and North Korea) have very limited Street View for legal or political reasons. When the embed below cannot find a panorama for an address, it quietly falls back to the normal map."}]]}],["$","section",null,{"className":"mt-10","children":[["$","h2",null,{"className":"font-display text-2xl font-bold","children":"How old is what you are looking at?"}],["$","p",null,{"className":"mt-3 text-fg-muted leading-relaxed","children":"Every Street View image is dated. Look at the bottom-left corner of the embed once it loads — the capture month and year are shown there. Busy city centres get refreshed every two or three years; smaller towns might still be showing imagery from five years ago. For historical research this is occasionally useful: Street View has a time-slider feature on the full Google Maps site that lets you scroll back through older captures of the same address."}]]}],["$","section",null,{"className":"mt-10","children":[["$","h2",null,{"className":"font-display text-2xl font-bold","children":"Privacy and what you can ask Google to blur"}],["$","p",null,{"className":"mt-3 text-fg-muted leading-relaxed","children":"Faces and licence plates are automatically blurred before any panorama is published. The blur is applied at upload time and is not reversible from the viewer side. If you find yourself or your home in the imagery and want it removed or further blurred, Google has a self-service report tool inside Maps — three dots, “Report a problem” — that handles requests for additional blurring within a few business days."}]]}],["$","section",null,{"className":"mt-10","children":[["$","h2",null,{"className":"font-display text-2xl font-bold","children":"Try these next"}],["$","div",null,{"className":"grid sm:grid-cols-2 lg:grid-cols-4 gap-3 mt-5","children":[["$","$L3","/my-location",{"href":"/my-location","className":"glass rounded-2xl p-4 hover:ring-accent/40 ring-1 ring-line transition no-underline","children":["$","h3",null,{"className":"font-display text-base font-bold text-fg hover:text-accent transition","children":"My Location"}]}],["$","$L3","/driving-directions",{"href":"/driving-directions","className":"glass rounded-2xl p-4 hover:ring-accent/40 ring-1 ring-line transition no-underline","children":["$","h3",null,{"className":"font-display text-base font-bold text-fg hover:text-accent transition","children":"Driving Directions"}]}],["$","$L3","/address-finder",{"href":"/address-finder","className":"glass rounded-2xl p-4 hover:ring-accent/40 ring-1 ring-line transition no-underline","children":["$","h3",null,{"className":"font-display text-base font-bold text-fg hover:text-accent transition","children":"Address Finder"}]}],["$","$L3","/gps-coordinates",{"href":"/gps-coordinates","className":"glass rounded-2xl p-4 hover:ring-accent/40 ring-1 ring-line transition no-underline","children":["$","h3",null,{"className":"font-display text-base font-bold text-fg hover:text-accent transition","children":"GPS Coordinates"}]}]]}]]}]]}]],null],null],null]},[null,["$","$L4",null,{"parallelRouterKey":"children","segmentPath":["children","street-view","children"],"error":"$undefined","e