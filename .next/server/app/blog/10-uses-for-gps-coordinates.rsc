0:["8BlH9t38bvsZhjHntO76k",[[["",{"children":["blog",{"children":[["slug","10-uses-for-gps-coordinates","d"],{"children":["__PAGE__?{\"slug\":\"10-uses-for-gps-coordinates\"}",{}]}]}]},"$undefined","$undefined",true],["",{"children":["blog",{"children":[["slug","10-uses-for-gps-coordinates","d"],{"children":["__PAGE__",{},[["$L1",[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"BlogPosting\",\"headline\":\"10 Surprising Uses for GPS Coordinates in Everyday Life\",\"description\":\"From geocaching to verifying VPNs to precision farming — ten practical things you can do once you know how to read your own latitude and longitude.\",\"datePublished\":\"2026-05-09\",\"dateModified\":\"2026-05-09\",\"author\":{\"@type\":\"Person\",\"name\":\"Ahmed Anwar\"},\"publisher\":{\"@type\":\"Organization\",\"name\":\"GetMyLocations\",\"logo\":{\"@type\":\"ImageObject\",\"url\":\"https://getmylocations.com/icon-512.png\"}},\"mainEntityOfPage\":{\"@type\":\"WebPage\",\"@id\":\"https://getmylocations.com/blog/10-uses-for-gps-coordinates\"}}"}}],["$","main",null,{"role":"main","className":"max-w-3xl mx-auto px-5 py-12","children":[["$","nav",null,{"aria-label":"Breadcrumb","className":"text-xs text-fg-subtle mb-4","children":[["$","$L2",null,{"href":"/","className":"hover:text-accent","children":"Home"}],["$","span",null,{"aria-hidden":"true","className":"mx-1.5","children":"/"}],["$","$L2",null,{"href":"/blog","className":"hover:text-accent","children":"Blog"}]]}],["$","h1",null,{"className":"font-display text-3xl sm:text-4xl font-extrabold tracking-tight leading-tight","children":"10 Surprising Uses for GPS Coordinates in Everyday Life"}],["$","div",null,{"className":"mt-4 flex items-center gap-3 flex-wrap","children":[["$","div",null,{"className":"flex items-center gap-2.5","children":[["$","div",null,{"className":"w-9 h-9 rounded-full bg-gradient-to-br from-accent to-accent-strong grid place-items-center text-accent-fg font-bold text-sm","aria-hidden":"true","children":"A"}],["$","div",null,{"className":"text-sm leading-tight","children":[["$","div",null,{"className":"font-semibold text-fg","children":"Ahmed Anwar"}],["$","div",null,{"className":"text-xs text-fg-subtle","children":[["$","time",null,{"dateTime":"2026-05-09","children":"May 9, 2026"}],["$","span",null,{"className":"mx-1.5","aria-hidden":"true","children":"·"}],["$","span",null,{"children":[6," min read"]}]]}]]}]]}],["$","ul",null,{"className":"flex gap-1.5 ml-auto","children":[["$","li","gps",{"className":"px-2 py-0.5 rounded-full bg-tint/5 ring-1 ring-line text-[11px] uppercase tracking-wider text-fg-muted","children":"gps"}],["$","li","use-cases",{"className":"px-2 py-0.5 rounded-full bg-tint/5 ring-1 ring-line text-[11px] uppercase tracking-wider text-fg-muted","children":"use-cases"}],["$","li","guide",{"className":"px-2 py-0.5 rounded-full bg-tint/5 ring-1 ring-line text-[11px] uppercase tracking-wider text-fg-muted","children":"guide"}]]}]]}],["$","hr",null,{"className":"my-8 border-line"}],["$","article",null,{"className":"prose-invert","children":[["$","p",null,{"className":"text-lg text-fg-muted leading-relaxed","children":"I have a note on my phone called “coords” with about thirty latitude–longitude pairs in it. The dentist’s side entrance because the front door is impossible to find at night. A particular tree in a friend’s farm where her family scattered her father’s ashes. The spot on a hiking trail where I once turned around because the weather closed in. None of these have addresses. All of them are usable in any map app in the world, on any device, forever, with no account or platform lock-in. That’s the underrated power of two numbers."}],["$","p",null,{"className":"mt-4 text-fg-muted leading-relaxed","children":"Most people only think about GPS coordinates when their navigation app refuses to find an address. Here are ten of the things I’ve actually used coordinates for — or watched friends use — that an address can’t handle."}],["$","h2",null,{"className":"font-display text-2xl font-bold mt-12","children":"1. Marking a place that has no address"}],["$","p",null,{"className":"mt-3 text-fg-muted leading-relaxed","children":"A favourite fishing hole. A tent site in the middle of a forest. The exact spot where a trail crosses a stream. The car park for a beach without a town. None of these have postal addresses, but every one has a coordinate. Save the lat/lon in your phone’s notes and you can return to the exact spot years later, in any navigation app you happen to be using by then."}],["$","h2",null,{"className":"font-display text-2xl font-bold mt-12","children":"2. Sharing your location in an emergency"}],["$","p",null,{"className":"mt-3 text-fg-muted leading-relaxed","children":["If you’re lost and 911/112 asks where you are, a six-decimal coordinate is the most precise answer you can give — accurate to within a meter or two. It works even when the dispatcher’s street-address lookup fails. Modern smartphones do this automatically via Advanced Mobile Location, but knowing how to read and say your own coordinates is the backup you want when AML doesn’t fire. Full walkthrough:"," ",["$","$L2",null,{"href":"/blog/gps-coordinates-emergencies-aml-guide","className":"text-accent hover:underline","children":"GPS coordinates in emergencies"}],"."]}],["$","h2",null,{"className":"font-display text-2xl font-bold mt-12","children":"3. Geotagging photos that lost their EXIF"}],["$","p",null,{"className":"mt-3 text-fg-muted leading-relaxed","children":"Instagram, WhatsApp, and most chat apps strip the EXIF metadata (including embedded GPS) from photos before posting. If you want to remember where a shot was taken, save the coordinates in a notes app or a photo-editor field at the moment you take it. I’ve gone back through years of holiday photos trying to reconstruct where each one was and lost the battle more than once."}],["$","h2",null,{"className":"font-display text-2xl font-bold mt-12","children":"4. Measuring exact distance between two places"}],["$","p",null,{"className":"mt-3 text-fg-muted leading-relaxed","children":["Need the straight-line distance between two coordinates — say, your home and a planned holiday rental? Plug them into the"," ",["$","$L2",null,{"href":"/distance-calculator","className":"text-accent hover:underline","children":"distance calculator"}]," ","and the Haversine formula returns the great-circle distance. This is how airlines calculate flight distances and how real-estate apps tell you a property is “4.2 km from the beach.”"]}],["$","h2",null,{"className":"font-display text-2xl font-bold mt-12","children":"5. Building a geofence"}],["$","p",null,{"className":"mt-3 text-fg-muted leading-relaxed","children":"A geofence is an invisible perimeter defined by a centre coordinate and a radius. Phone automations (iOS Shortcuts, Android Tasker, Home Assistant) trigger actions when you cross one: turn on the lights when you arrive home, silence notifications when you walk into the office, remind you to pick up something when you’re near the supermarket. The whole setup needs one coordinate to start."}],["$","h2",null,{"className":"font-display text-2xl font-bold mt-12","children":"6. Proving (or disproving) a delivery"}],["$","p",null,{"className":"mt-3 text-fg-muted leading-relaxed","children":"Some delivery apps share the courier’s drop-off coordinates as part of the confirmation. If a driver claims “delivered” but no package arrives, comparing their reported drop-off coordinate to your home coordinate can show the package was left at the wrong address — useful evidence in a refund claim, useful information for the courier company when they investigate."}],["$","h2",null,{"className":"font-display text-2xl font-bold mt-12","children":"7. Geocaching"}],["$","p",null,{"className":"mt-3 text-fg-muted leading-relaxed","children":"Over three million caches are hidden around the world, each pinpointed by a precise GPS coordinate. Players use the coordinate alone — no other directions, no street address — to find a small container, log their visit, sometimes swap a trinket. The game is the reason the consumer GPS market exists at all; it’s where Garmin and Magellan first found non-professional customers in the early 2000s."}],["$","h2",null,{"className":"font-display text-2xl font-bold mt-12","children":"8. Sanity-checking your VPN"}],["$","p",null,{"className":"mt-3 text-fg-muted leading-relaxed","children":["Connect to a VPN that claims to be in Tokyo, then open"," ",["$","$L2",null,{"href":"/ip-location","className":"text-accent hover:underline","children":"IP Location"}],". If it places you near Tokyo, the IP-based signal is leaking properly. If your real city shows up instead, the VPN has a DNS or WebRTC leak somewhere and you should know about it before you trust it for anything sensitive. Two clicks beats guessing."]}],["$","h2",null,{"className":"font-display text-2xl font-bold mt-12","children":"9. Plotting weather stations and microclimates"}],["$","p",null,{"className":"mt-3 text-fg-muted leading-relaxed","children":"Personal weather stations from Davis, Tempest, and Ambient ask for exact GPS coordinates during setup so the public weather network knows where each reading came from. Hyperlocal forecasting is built on dense, coordinate-tagged sensor networks. The Tempest network, for instance, pulls in around a hundred thousand backyard stations now — each one a coordinate plus a temperature, pressure, and wind reading feeding back into the forecast model."}],["$","h2",null,{"className":"font-display text-2xl font-bold mt-12","children":"10. Precision agriculture"}],["$","p",null,{"className":"mt-3 text-fg-muted leading-relaxed","children":"Modern tractors use centimetre-accurate GPS to drive themselves along perfectly parallel rows, drop fertiliser on the exact square meter where soil samples flagged a deficiency, and stop seeding the moment they cross a known “bad” patch. The savings on inputs (water, seed, fertiliser) regularly hit double-digit percentages — a direct consequence of GPS coordinates getting cheap and precise enough to be a routine farm input."}],["$","h2",null,{"className":"font-display text-2xl font-bold mt-12","children":"Bonus: a privacy-friendly way to share a property listing"}],["$","p",null,{"className":"mt-3 text-fg-muted leading-relaxed","children":"Selling a property privately? Share the listing photo with the coordinate pasted underneath. The recipient can click straight into Maps or Street View to evaluate the neighbourhood — no street address publicly listed, no leak of full identifying information, but enough for a serious buyer to do their initial homework. The same trick works for short-term rentals where you want guests to find the door without putting the exact unit number on a public booking page."}],["$","h2",null,{"className":"font-display text-2xl font-bold mt-12","children":"How to grab a coordinate in two seconds"}],["$","p",null,{"className":"mt-3 text-fg-muted leading-relaxed","children":["Whenever you need a coordinate for any of the above — open"," ",["$","$L2",null,{"href":"/","className":"text-accent hover:underline font-semibold","children":"GetMyLocations"}],", approve the location prompt, copy the six-decimal lat/lon from the dashboard. Paste it into your notes app and it’ll still work in 2036."]}]]}],["$","aside",null,{"aria-label":"About the author","className":"mt-14 not-prose rounded-2xl border border-line bg-white/[0.03] p-6 sm:p-7","children":["$","div",null,{"className":"flex items-start gap-4","children":[["$","div",null,{"aria-hidden":"true","className":"shrink-0 w-12 h-12 rounded-full bg-gradient-to-br from-accent to-accent-strong flex items-center justify-center font-bold text-accent-fg","children":"AA"}],["$","div",null,{"className":"min-w-0","children":[["$","p",null,{"className":"text-xs uppercase tracking-[0.16em] text-accent font-semibold","children":"Written by"}],["$","h3",null,{"className":"font-display text-lg font-bold text-fg mt-1","children":"Ahmed Anwar"}],["$","p",null,{"className":"text-sm text-fg-muted leading-relaxed mt-2","children":"Independent web developer in Karachi. Builds the geolocation tools, mapping pages, and coordinate utilities on GetMyLocations. Writes about GPS, browser geolocation, and IP geolocation from the perspective of someone who ships the code, not the marketing."}],["$","p",null,{"className":"text-xs text-fg-subtle mt-3 leading-relaxed","children":["This article was researched and drafted with AI assistance, then edited and fact-checked by Ahmed before publication."," ",["$","$L2",null,{"href":"/about","className":"text-accent hover:underline","children":"More about the author"}],"."]}]]}]]}]}],["$","$L2",null,{"href":"/blog","className":"block mt-10 text-sm text-accent hover:underline","children":"← Back to all posts"}]]}]],null],null],null]},[null,["$","$L3",null,{"parallelRouterKey":"children","segmentPath":["children","blog","children","$4","children"],"error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L5",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound":"$undefined","notFoundStyles":"$undefined"}]],null]},[null,["$","$L3",null,{"parallelRouterKey":"children","segmentPath":["children","blog","children"],"error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L5",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound":"$undefined","notFoundStyles":"$undefined"}]],null]},[[[["$","link","0",{"rel":"stylesheet","href":"/_next/static/css/7fd04e74a3762014.css","precedence":"next","crossOrigin":"$undefined"}]],["$","html",null,{"lang":"en","dir":"ltr","data-theme":"light","children":[["$","head",null,{"children":[["$","link",null,{"rel":"preconnect","href":"https://fonts.googleapis.com"}],["$","link",null,{"rel":"preconnect","href"