0:["8BlH9t38bvsZhjHntO76k",[[["",{"children":["blog",{"children":[["slug","gps-coordinates-emergencies-aml-guide","d"],{"children":["__PAGE__?{\"slug\":\"gps-coordinates-emergencies-aml-guide\"}",{}]}]}]},"$undefined","$undefined",true],["",{"children":["blog",{"children":[["slug","gps-coordinates-emergencies-aml-guide","d"],{"children":["__PAGE__",{},[["$L1",[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"BlogPosting\",\"headline\":\"GPS Coordinates in Emergencies — The Complete AML & 911/112 Guide\",\"description\":\"How emergency dispatchers use coordinates, what Advanced Mobile Location does automatically, when to read your own coordinates, and how to communicate them over the phone.\",\"datePublished\":\"2026-05-20\",\"dateModified\":\"2026-05-20\",\"author\":{\"@type\":\"Person\",\"name\":\"Ahmed Anwar\"},\"publisher\":{\"@type\":\"Organization\",\"name\":\"GetMyLocations\",\"logo\":{\"@type\":\"ImageObject\",\"url\":\"https://getmylocations.com/icon-512.png\"}},\"mainEntityOfPage\":{\"@type\":\"WebPage\",\"@id\":\"https://getmylocations.com/blog/gps-coordinates-emergencies-aml-guide\"}}"}}],["$","main",null,{"role":"main","className":"max-w-3xl mx-auto px-5 py-12","children":[["$","nav",null,{"aria-label":"Breadcrumb","className":"text-xs text-fg-subtle mb-4","children":[["$","$L2",null,{"href":"/","className":"hover:text-accent","children":"Home"}],["$","span",null,{"aria-hidden":"true","className":"mx-1.5","children":"/"}],["$","$L2",null,{"href":"/blog","className":"hover:text-accent","children":"Blog"}]]}],["$","h1",null,{"className":"font-display text-3xl sm:text-4xl font-extrabold tracking-tight leading-tight","children":"GPS Coordinates in Emergencies — The Complete AML & 911/112 Guide"}],["$","div",null,{"className":"mt-4 flex items-center gap-3 flex-wrap","children":[["$","div",null,{"className":"flex items-center gap-2.5","children":[["$","div",null,{"className":"w-9 h-9 rounded-full bg-gradient-to-br from-accent to-accent-strong grid place-items-center text-accent-fg font-bold text-sm","aria-hidden":"true","children":"A"}],["$","div",null,{"className":"text-sm leading-tight","children":[["$","div",null,{"className":"font-semibold text-fg","children":"Ahmed Anwar"}],["$","div",null,{"className":"text-xs text-fg-subtle","children":[["$","time",null,{"dateTime":"2026-05-20","children":"May 20, 2026"}],["$","span",null,{"className":"mx-1.5","aria-hidden":"true","children":"·"}],["$","span",null,{"children":[10," min read"]}]]}]]}]]}],["$","ul",null,{"className":"flex gap-1.5 ml-auto","children":[["$","li","emergency",{"className":"px-2 py-0.5 rounded-full bg-tint/5 ring-1 ring-line text-[11px] uppercase tracking-wider text-fg-muted","children":"emergency"}],["$","li","gps",{"className":"px-2 py-0.5 rounded-full bg-tint/5 ring-1 ring-line text-[11px] uppercase tracking-wider text-fg-muted","children":"gps"}],["$","li","safety",{"className":"px-2 py-0.5 rounded-full bg-tint/5 ring-1 ring-line text-[11px] uppercase tracking-wider text-fg-muted","children":"safety"}]]}]]}],["$","hr",null,{"className":"my-8 border-line"}],["$","article",null,{"className":"prose-invert","children":[["$","p",null,{"className":"text-lg text-fg-muted leading-relaxed","children":"In 2014, a Lithuanian teenager named Karol Otulakowski phoned the emergency services from a forest. He couldn’t describe where he was. He died before the call handler could find him. That call is one of the cases the European Emergency Number Association cites every time they push for Advanced Mobile Location — the technology that now automatically sends a caller’s GPS coordinates to the dispatcher the instant they dial 112 or 911, with no app to install and no permission to grant."}],["$","p",null,{"className":"mt-4 text-fg-muted leading-relaxed","children":"AML covers most of the world’s urban emergencies now, but it has gaps. Landlines don’t use it. VoIP apps don’t use it. Older networks haven’t upgraded. The single skill worth practising once, when you don’t need it, is reading your own coordinates off your phone and saying them out loud to a dispatcher. The rest of this article is what I worked out about how that whole pipeline functions, and where the brittle bits are."}],["$","h2",null,{"className":"font-display text-2xl font-bold mt-12","children":"What happens at the dispatch centre"}],["$","p",null,{"className":"mt-3 text-fg-muted leading-relaxed","children":"Every modern dispatch centre (PSAP, public safety answering point) runs a computer-aided dispatch system with a built-in map. When a coordinate is entered — either manually by the dispatcher or automatically from AML — the map zooms straight to the spot, overlays the nearest streets, and routes the closest available unit. The whole pipeline, from coordinate received to ambulance dispatched, can take under a minute in well-equipped centres."}],["$","p",null,{"className":"mt-3 text-fg-muted leading-relaxed","children":"The console is also doing reverse geocoding in the background: turning the coordinate back into a human-readable address (“14th and Main, opposite the pharmacy”) so the responding crew can call out the destination over the radio. This is why supplying a coordinate is more useful than supplying an address — the coordinate is the canonical reference, the address text is derived from it."}],["$","h2",null,{"className":"font-display text-2xl font-bold mt-12","children":"What your phone does automatically"}],["$","p",null,{"className":"mt-3 text-fg-muted leading-relaxed","children":["Since the late 2010s, both iOS (under the name Hybridized Emergency Location, HELO) and Android have shipped",["$","strong",null,{"children":" Advanced Mobile Location"}],". The instant you dial an emergency number, the phone:"]}],["$","ol",null,{"className":"mt-3 space-y-2 text-fg-muted list-decimal list-inside","children":[["$","li",null,{"children":"Turns on GPS, Wi-Fi, and cellular positioning at maximum accuracy — even if you had location services off."}],["$","li",null,{"children":"Computes the best available fix within a few seconds."}],["$","li",null,{"children":"Transmits the coordinates and an accuracy estimate to the dispatcher over a secure side-channel."}],["$","li",null,{"children":"Drops the elevated positioning the moment you hang up."}]]}],["$","p",null,{"className":"mt-3 text-fg-muted leading-relaxed","children":"It works without the caller doing anything. It works whether or not the user has granted location permission to any app — emergency calls bypass the normal permission model. It works in airplane mode if the cellular for the emergency call itself comes back up."}],["$","p",null,{"className":"mt-3 text-fg-muted leading-relaxed","children":"Coverage is uneven. AML is mandatory in most EU member states, the UK, Australia, and New Zealand, and is rolled out in many US states under the Next Generation 911 programme. Pakistan’s 15 service and India’s 112 are adopting it incrementally. The official EENA list tracks who has switched on the receiving infrastructure."}],["$","h2",null,{"className":"font-display text-2xl font-bold mt-12","children":"When AML isn’t there to save you"}],["$","p",null,{"className":"mt-3 text-fg-muted leading-relaxed","children":"AML covers the common case beautifully. The cases where it fails are exactly the ones where having a manual backup matters most:"}],["$","ul",null,{"className":"mt-3 space-y-2 text-fg-muted list-disc list-inside","children":[["$","li",null,{"children":[["$","strong",null,{"children":"Landline calls."}]," AML is a smartphone feature. A landline call relies on the registered service address, which may be the building manager’s office and not your flat."]}],["$","li",null,{"children":[["$","strong",null,{"children":"VoIP calls."}]," WhatsApp calls to emergency numbers, Skype calls, and most carrier-VoIP setups don’t carry AML payloads."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Countries that haven’t deployed it."}]," Big parts of central Asia, Africa, and the Americas don’t yet receive AML even from compliant phones."]}],["$","li",null,{"children":[["$","strong",null,{"children":"You’re calling about someone else."}]," AML reports the calling phone’s position, not the incident’s. If you’re calling from a kilometre away because you can’t reach the person, the dispatcher needs the incident coordinate from you verbally."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Maritime, aviation, or wilderness."}]," Coast guard and mountain rescue dispatchers usually want coordinates spoken aloud or transmitted by satellite messenger, regardless of phone-side automation."]}],["$","li",null,{"children":[["$","strong",null,{"children":"The dispatcher is overwhelmed."}]," In a mass incident, even where AML works, the dispatcher may need to confirm the coordinate verbally to make sure the system displayed the right one."]}]]}],["$","h2",null,{"className":"font-display text-2xl font-bold mt-12","children":"Reading your coordinates — per device"}],["$","h3",null,{"className":"font-display text-lg font-semibold mt-6 text-fg","children":"iPhone"}],["$","ol",null,{"className":"mt-2 space-y-2 text-fg-muted list-decimal list-inside","children":[["$","li",null,{"children":"Open the Compass app (pre-installed). Coordinates sit at the bottom of the screen."}],["$","li",null,{"children":"Or open Apple Maps, tap the blue location dot, swipe up on the info panel, and the coordinates are listed under “My Location”."}],["$","li",null,{"children":"Long-press to copy."}]]}],["$","h3",null,{"className":"font-display text-lg font-semibold mt-6 text-fg","children":"Android"}],["$","ol",null,{"className":"mt-2 space-y-2 text-fg-muted list-decimal list-inside","children":[["$","li",null,{"children":"Open Google Maps."}],["$","li",null,{"children":"Long-press anywhere on the map at your location — a red pin appears."}],["$","li",null,{"children":"The coordinates appear in the search bar at the top. Tap to copy."}]]}],["$","h3",null,{"className":"font-display text-lg font-semibold mt-6 text-fg","children":"Any browser"}],["$","p",null,{"className":"mt-2 text-fg-muted leading-relaxed","children":["Open ",["$","$L2",null,{"href":"/","className":"text-accent hover:underline font-semibold","children":"GetMyLocations"}],". Click Allow on the location prompt. The coordinates appear in the dashboard with a one-click copy button."]}],["$","h3",null,{"className":"font-display text-lg font-semibold mt-6 text-fg","children":"Garmin or a dedicated GPS unit"}],["$","p",null,{"className":"mt-2 text-fg-muted leading-relaxed","children":"Most outdoor handhelds have a “Where am I?” menu that shows current coordinates, plus an emergency mode that strips the screen down to coordinates and a panic button."}],["$","h2",null,{"className":"font-display text-2xl font-bold mt-12","children":"Saying the numbers out loud"}],["$","p",null,{"className":"mt-3 text-fg-muted leading-relaxed","children":"Two formats are common. Either works with most dispatchers, but tell them which one you’re reading from:"}],["$","ul",null,{"className":"mt-3 space-y-2 text-fg-muted list-disc list-inside","children":[["$","li",null,{"children":[["$","strong",null,{"children":"Decimal degrees:"}]," “forty-eight point eight five eight four, two point two nine four five.”"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Degrees, minutes, seconds:"}]," “forty-eight degrees, fifty-one minutes, thirty seconds North; two degrees, seventeen minutes, forty seconds East.”"]}]]}],["$","p",null,{"className":"mt-3 text-fg-muted leading-relaxed","children":"Speak slowly. Read each digit individually (“eight five eight four”, not “eight thousand five hundred eighty-four”). Dispatchers are trained to write digits, and a single mishearing can drop rescuers 100 meters off. When they read the number back, listen for the read-back to match exactly and confirm verbally."}],["$","h2",null,{"className":"font-display text-2xl font-bold mt-12","children":"What3Words, Plus Codes, and why I still prefer raw numbers"}],["$","p",null,{"className":"mt-3 text-fg-muted leading-relaxed","children":["Several services tag 3-meter squares of the world with memorable codes. ",["$","strong",null,{"children":"What3Words"}]," assigns three random words to each square (“filled.count.soap”); ",["$","strong",null,{"children":"Plus Codes"}]," use a short alphanumeric format. Some emergency services accept either — the UK’s 999 service supports both What3Words and AML, for instance."]}],["$","p",null,{"className":"mt-3 text-fg-muted leading-relaxed","children":"In an emergency I would still prefer raw coordinates. Decimal degrees are universally understood; they don’t require the dispatcher to have a particular company’s lookup tool open; they don’t depend on the call being in English; they work on every dispatch system in the world. The branded formats are useful as a backup or for places where the address-system genuinely doesn’t exist (rural Mongolia, refugee camps), but for the twenty-second window where the dispatcher is asking where you are, raw numbers are the safer bet."}],["$","h2",null,{"className":"font-display text-2xl font-bold mt-12","children":"Things to do before you ever need this"}],["$","ul",null,{"className":"mt-3 space-y-2 text-fg-muted list-disc list-inside","children":[["$","li",null,{"children":"Make sure Location Services / GPS is enabled at the OS level. AML can’t fire if the chip is off."}],["$","li",null,{"children":"Set up your phone’s emergency contacts and Medical ID. They’re visible from the lock screen and save dispatchers a step."}],["$","li",null,{"children":"Memorise the emergency number for where you actually are. It’s not always 911. EU: 112. UK: 999. Pakistan: 15. India: 112. Australia: 000."}],["$","li",null,{"children":"For wilderness work, carry a satellite messenger (Garmin inReach, ZOLEO, the newer iPhones’ Emergency SOS via Satellite). They work where cellular doesn’t."}],["$","li",null,{"children":"If you travel internationally, install the regional 112 / 999 app of the country you’re visiting. Many countries have one."}]]}],["$","h2",null,{"className":"font-display text-2xl font-bold mt-12","children":"Reporting an incident that isn’t happening to you"}],["$","p",null,{"className":"mt-3 text-fg-muted leading-relaxed","children":["If you witness an emergency that’s a few meters away — a road accident, a person collapsing on a trail — AML sends",["$","em",null,{"children":" your"}]," location, not the incident’s. Verbally confirm the incident location separately, ideally a coordinate you’ve read off your own phone after walking close enough to the scene that the GPS reading is reliable."]}],["$","p",null,{"className":"mt-3 text-fg-muted leading-relaxed","children":"On highways, naming the nearest kilometre-marker post is often faster than coordinates. Inside large parks or campuses, the opposite is true — a coordinate beats “by the main gate” every time."}],["$","h2",null,{"className":"font-display text-2xl font-bold mt-12","children":"Practise once, when nothing is wrong"}],["$","p",null,{"className":"mt-3 text-fg-muted leading-relaxed","children":["The single most useful exercise is to read your coordinates off your phone right now, in a low-stakes moment, just to know what the process feels like. Open"," ",["$","$L2",null,{"href":"/","className":"text-accent hover:underline font-semibold","children":"GetMyLocations"}],", see the numbers, get a feel for what “24.860422, 67.001137” looks and sounds like. The next time you need to say it under stress, it’ll take you ten seconds instead of two minutes — and you’ll know the screen flow already."]}]]}],["$","aside",null,{"aria-label":"About the author","className":"mt-14 not-prose rounded-2xl border border-line bg-white/[0.03] p-6 sm:p-7","children":["$","div",null,{"className":"flex items-start gap-4","children":[["$","div",null,{"aria-hidden":"true","className":"shrink-0 w-12 h-12 rounded-full bg-gradient-to-br from-accent to-accent-strong flex items-center justify-center font-bold text-accent-fg","children":"AA"}],["$","div",null,{"className":"min-w-0","children":[["$","p",null,{"className":"text-xs uppercase tracking-[0.16em] text-accent font-semibold","children":"Written by"}],["$","h3",null,{"className":"font-display text-lg font-bold text-fg mt-1","children":"Ahmed Anwar"}],["$","p",null,{"className":"text-sm text-fg-muted leading-relaxed mt-2","children":"Independent web developer in Karachi. Builds the geolocation tools, mapping pages, and coordinate utilities on GetMyLocations. Writes about GPS, browser geolocation, and IP geolocation from the perspective of someone who ships the code, not the marketing."}],["$","p",null,{"className":"text-xs text-fg-subtle mt-3 leading-relaxed","children":["This article was researched and drafted with AI assistance, then edited and fact-checked by Ahmed before publication."," ",["$","$L2",null,{"href":"/about","className":"text-accent hover:underline","children":"More about the author"}],"."]}]]}]]}]}],["$","$L2",null,{"href":"/blog","className":"block mt-10 text-sm text-accent hover:underline","children":"← Back to all posts"}]]}]],null],null],null]},[null,["$","$L3",null,{"parallelRouterKey":"children","segmentPath":["children","blog","children","$4","children"],"error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L5",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound":"$undefined","notFoundStyles":"$undefined"}]],null]},[null,["$","$L3",null,{"parallelRouterKey":"children","segmentPath":["children","blog","children"],"error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L5",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound":"$undefined","notFoundStyles":"$undefined"}]],null]},[[[["$","link